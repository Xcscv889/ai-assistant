# AI Office Assistant 环境变量配置
# 复制此文件为 .env 并填入实际的 API Key

# ============================================
# LLM API Keys
# ============================================
ANTHROPIC_API_KEY=sk-ant-xxxxx
OPENAI_API_KEY=sk-xxxxx
DEEPSEEK_API_KEY=sk-xxxxx

# Ollama 本地地址（默认 http://localhost:11434）
OLLAMA_BASE_URL=http://localhost:11434

# ============================================
# 飞书应用配置
# ============================================
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# ============================================
# 企业微信 Webhook
# ============================================
WECOM_WEBHOOK_URL=

# ============================================
# 钉钉 Webhook
# ============================================
DINGTALK_WEBHOOK_URL=

# ============================================
# 搜索 API（可选，Tavily 提供更高质量搜索）
# ============================================
TAVILY_API_KEY=

# ============================================
# 应用配置
# ============================================
APP_DEBUG=false
APP_LOG_LEVEL=INFO
